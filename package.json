{
  "name": "project-wiki-bootstrap",
  "version": "0.1.0",
  "description": "Bootstrap a token-efficient project planning wiki for humans and LLM agents.",
  "license": "MIT",
  "type": "commonjs",
  "keywords": [
    "agents",
    "claude-code",
    "codex",
    "llm",
    "project-planning",
    "wiki"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkjk1176/project-wiki-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/kkjk1176/project-wiki-bootstrap/issues"
  },
  "homepage": "https://github.com/kkjk1176/project-wiki-bootstrap#readme",
  "files": [
    "agents/",
    "dist/",
    "LICENSE",
    "README.md",
    "README.ko.md",
    "README.ja.md",
    "README.zh.md",
    "SKILL.md"
  ],
  "bin": {
    "project-wiki-bootstrap": "dist/init-project-wiki.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/init-project-wiki.js",
